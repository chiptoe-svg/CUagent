# Dependencies
node_modules/
.npm-cache/
# Build output
dist/

# Local data & auth
store/
data/
logs/

# Groups - only track AGENT.md persona files
groups/*
!groups/global/
!groups/telegram_main/
groups/global/*
groups/telegram_main/*
!groups/global/AGENT.md
!groups/global/AGENT-reference.md
!groups/telegram_main/AGENT.md
!groups/telegram_main/AGENT-reference.md

# Secrets
*.keys.json
.env

# Cryptographic material
*.pem
*.key
*.pfx
*.p12
*.crt
*.cer

# Token caches and credential stores
.msal-cache/
.tokens/
.auth/
.credentials/

# Private approval / compliance records
docs/*.private.md
docs/*ticket*.md

# Local institution-specific config (deep-merged over the public defaults)
config/*.local.json
config/*private*.json
config/*secrets*.json

# Temp files
.tmp-*

